# Local Postgres (matches docker-compose.yml)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=alex
POSTGRES_USER=alex
POSTGRES_PASSWORD=alex_local_dev

# SQLAlchemy URL consumed by Alembic
DATABASE_URL=postgresql+psycopg://alex:alex_local_dev@localhost:5432/alex

# Default vector dimension for pgvector columns. Phase 2 work orders may override
# per embedding model; keep this in sync with the EmbeddingIndexer when set.
EMBEDDING_DIM=1536

# Agent Runtime (services/agent-runtime)
AGENT_RUNTIME_HOST=0.0.0.0
AGENT_RUNTIME_PORT=8000

# Claude Agent SDK
# Leave ANTHROPIC_API_KEY empty for local dev — the runtime falls back to
# StubAgentBackend so the service still boots without calling a real model.
ANTHROPIC_API_KEY=
# Override for EU residency. Empty = use SDK default.
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-sonnet-4-6

# HTTP header that inbound /events and /callbacks requests use to carry the
# tenant uuid. Pipedream and the Slack/Teams surfaces set this; without it the
# request is rejected with 400.
TENANT_HEADER=X-Tenant-Id

# Internal scheduler heartbeat interval (seconds).
SCHEDULER_HEARTBEAT_SECONDS=60

# Webhook signing (HMAC-SHA256) for Pipedream → Agent Runtime and (later)
# Slack/Teams → Agent Runtime callbacks. Leave empty in local dev to bypass
# verification; set in production and mirror the value in Pipedream's env.
ALEX_WEBHOOK_SECRET=
WEBHOOK_SIGNATURE_HEADER=X-Alex-Signature
WEBHOOK_TIMESTAMP_HEADER=X-Alex-Timestamp
WEBHOOK_SIGNATURE_MAX_AGE_SECONDS=300
